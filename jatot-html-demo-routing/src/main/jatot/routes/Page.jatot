package io.jatot.html.demo.routes;

import io.jatot.html.Component;
import io.jatot.html.Html;
import io.jatot.html.spring.Prerender;

@Prerender
public record Page() implements Component {

    @Override
    public Html render() {
        return (
            <main>
                <h1>Welcome to Jatot Routing!</h1>
                <p>Go to <a href="/users/Mel">User: Mel</a></p>
            </main>
        );
    }
}
