package io.jatot.html.demo.routes.users._name;

import io.jatot.html.Component;
import io.jatot.html.Html;
import io.jatot.html.demo.User;
import io.jatot.html.demo.UserCard;

public record Page(User user) implements Component {

    @Override
    public Html render() {
        return (
            <UserCard user={this.user} />
        );
    }
}
