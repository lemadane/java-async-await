package io.jatot.html.demo;

import io.jatot.html.Component;
import io.jatot.html.Html;

public record UserCard(User user) implements Component {

    @Override
    public Html render() {
        return (
            <article class="user-card">
                <h2>{this.user.name()}</h2>
                <p>{this.user.email()}</p>
            </article>
        );
    }
}
